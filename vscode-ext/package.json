{
  "name": "memu8086",
  "displayName": "MEMU8086",
  "description": "A modern Intel 8086 emulator and assembler.",
  "author": "Animesh Barua Mugdha",
  "publisher": "stup702",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stup702/Memu8086"
  },
  "version": "0.7.85",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers",
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "asm",
        "aliases": [
          "Assembly",
          "asm",
          "x86"
        ],
        "extensions": [
          ".asm",
          ".inc",
          ".s"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "asm",
        "scopeName": "source.asm",
        "path": "./syntaxes/asm.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "memu8086-sidebar",
          "title": "MEMU8086",
          "icon": "$(chip)"
        }
      ]
    },
    "views": {
      "memu8086-sidebar": [
        {
          "type": "webview",
          "id": "memu8086.dashboardView",
          "name": "Dashboard"
        }
      ]
    },
    "debuggers": [
      {
        "type": "memu8086",
        "label": "MEMU8086 Debug",
        "program": "./out/debugAdapter.js",
        "runtime": "node"
      }
    ],
    "commands": [
      {
        "command": "memu8086.chippingIn",
        "title": "MEMU8086: Chipping In",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "memu8086.dashboardView.focus",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "memu8086.chippingIn",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0"
  }
}
