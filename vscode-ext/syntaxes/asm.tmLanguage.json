{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Assembly (x86)",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#labels"
        },
        {
            "include": "#registers"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#instructions"
        },
        {
            "include": "#directives"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.semicolon.asm",
                    "match": ";.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.asm",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.asm",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.asm",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.asm",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "labels": {
            "patterns": [
                {
                    "name": "entity.name.function.label.asm",
                    "match": "^\\s*[A-Za-z_][A-Za-z0-9_]*:"
                }
            ]
        },
        "registers": {
            "patterns": [
                {
                    "name": "variable.language.register.asm",
                    "match": "(?i)\\b(ax|bx|cx|dx|al|ah|bl|bh|cl|ch|dl|dh|si|di|sp|bp|ip|cs|ds|es|ss)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.asm",
                    "match": "(?i)\\b0x[0-9a-f]+\\b|\\b[0-9a-f]+h\\b"
                },
                {
                    "name": "constant.numeric.binary.asm",
                    "match": "(?i)\\b[01]+b\\b"
                },
                {
                    "name": "constant.numeric.decimal.asm",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "instructions": {
            "patterns": [
                {
                    "name": "keyword.control.instruction.asm",
                    "match": "(?i)\\b(mov|add|sub|inc|dec|cmp|jmp|je|jne|jz|jnz|jg|jge|jl|jle|ja|jae|jb|jbe|call|ret|push|pop|int|out|in|hlt|nop|mul|div|imul|idiv|and|or|xor|not|shl|shr|sal|sar|rol|ror|rcl|rcr|loop|loope|loopne|loopz|loopnz|iret|lea)\\b"
                }
            ]
        },
        "directives": {
            "patterns": [
                {
                    "name": "keyword.other.directive.asm",
                    "match": "(?i)\\b(db|dw|dd|equ|org)\\b"
                }
            ]
        }
    },
    "scopeName": "source.asm"
}
